  m_Script: {fileID: 11500000, guid: c22685b415d006c448daa1f0ed496bfd, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Moral_Support
  visitors:
  - {fileID: 0}
  - {fileID: 0}
  - {fileID: 0}
  - {fileID: 0}
  - {fileID: 0}
  - {fileID: 0}
  panel: {fileID: 0}
  text: {fileID: 0}
  wiggle_room: 0.001
  exponential_power: 1.97
  texts:
  - Good luck,  my friend!
  - Hey there, friend! Don't give up!
  - Patience is a virtue.
  - What's going on here?
  - Is there a narrative to this game?
  - HELPPPP!!! No I'm just playing around, I don't need any help.
  - Today has been quite a day.
  - Who am I? I'm the dark blue tile. I am here for moral support. GO TEAM GO!!
  - How we doing. You doing alright?
  - Gimme a P. P! Gimme a L. L! Gimme an... nah I'm too tired for this.
  - I unfortunately can't help you very much :((
  - Have you tried the tutorial yet? Highly recommend.
  - Time is of the essence. Chop chop!!
  - Each of the cars have such unique behaviors! Absolutely astounding.
  - Who are you anyways, a police car?
  - It looks like you have to move the cars. Why you gotta move the cars? What did
    they do to you?
  - Everybody seems to have a home except for that big, sturdy van. Maybe they already
    home.
  activation_time: 1
